---
import Nav from '../components/Nav.astro';
import SpeedInsights from '@vercel/speed-insights/astro';
import { ViewTransitions } from 'astro:transitions';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  ogTitle?: string;
  ogDescription?: string;
  ogUrl?: string;
  currentPath: string;
  containerClass?: string;
  missingText?: string;
}

const {
  title,
  description,
  ogTitle,
  ogDescription,
  ogUrl,
  currentPath,
  containerClass = 'max-w-6xl',
  missingText = "Know a scholarship we're missing?",
} = Astro.props;
---

<html lang="en" class="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta property="og:title" content={ogTitle ?? title} />
    <meta property="og:description" content={ogDescription ?? description} />
    <meta property="og:type" content="website" />
    {ogUrl && <meta property="og:url" content={ogUrl} />}
    <meta name="twitter:card" content="summary_large_image" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <!-- Syne -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&display=swap" />
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&display=swap" rel="stylesheet" />
    <!-- Body font -->
    <link rel="preconnect" href="https://api.fontshare.com" />
    <link rel="preload" as="style" href="https://api.fontshare.com/v2/css?f[]=general-sans@400,500,600&display=swap" />
    <link href="https://api.fontshare.com/v2/css?f[]=general-sans@400,500,600&display=swap" rel="stylesheet" />
    <script is:inline>
      (function () {
        try {
          var t = localStorage.getItem('theme') || 'dark';
          document.documentElement.classList.toggle('dark', t === 'dark');
        } catch (e) {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>
    <ViewTransitions />
  </head>
  <body class="bg-[#f5f5fa] dark:bg-[#0a0a0f] text-gray-900 dark:text-white min-h-screen flex flex-col overflow-x-hidden">
    <div class={`${containerClass} mx-auto w-full flex-1 px-4 pt-2 pb-8 md:px-8`}>
      <Nav currentPath={currentPath} />
      <slot />
    </div>
    <footer class="border-t border-black/5 dark:border-white/[0.06] mt-8 relative" style="z-index:1;">
      <div class={`${containerClass} mx-auto px-4 py-6 md:px-8 flex flex-col sm:flex-row sm:justify-between sm:items-center gap-4 text-sm text-black/30 dark:text-white/25`}>
        <span>© 2026 ScholarAB &nbsp;·&nbsp; Made in Medicine Hat, Alberta.</span>
        <div class="flex flex-wrap gap-5">
          <a href="mailto:scholarab@gmail.com" class="hover:text-black/60 dark:hover:text-white/50 transition-colors">{missingText}</a>
        </div>
      </div>
    </footer>
    <SpeedInsights />
  </body>
</html>
